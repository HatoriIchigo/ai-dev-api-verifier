{
  "projectName": "sample",
  "openapi": "examples/openapi.yaml",
  "top": [
    {
      "operationId": "loginAccount",
      "entry": "top/LoginAccount",
      "path": "/accounts/login",
      "method": "POST",
      "description": "ログインID・パスワード:認証情報を検証しトークンを発行:アクセストークン",
      "imports": [
        "layer2/AccountService"
      ]
    },
    {
      "operationId": "getAccount",
      "entry": "top/GetAccount",
      "path": "/accounts/{userId}",
      "method": "GET",
      "description": "ユーザID:アカウント情報を取得:アカウント詳細",
      "imports": [
        "layer2/AccountService"
      ]
    },
    {
      "operationId": "checkHealth",
      "entry": "internal/CheckHealth",
      "path": "/health",
      "method": "GET",
      "description": "なし:アプリ稼働状態を点検:ヘルスステータス",
      "imports": [
        "internal/HealthChecker"
      ]
    }
  ],
  "layer": {
    "layer1": [
      {
        "name": "AccountStore",
        "description": "アカウントID:repository 経由でアカウントを取得:アカウントエンティティ",
        "imports": [
          "repository/AccountRepository"
        ]
      }
    ],
    "layer2": [
      {
        "name": "AccountService",
        "description": [
          "ログイン要求:認証情報を検証して結果を返す:認証結果",
          "ユーザID:アカウント情報を整形して返す:アカウント詳細"
        ],
        "imports": [
          "layer1/AccountStore"
        ]
      }
    ]
  },
  "internal": {
    "HealthChecker": [
      {
        "name": "HealthChecker",
        "description": "なし:アプリ稼働状態を判定する:稼働可否"
      }
    ]
  },
  "repository": [
    {
      "name": "AccountRepository",
      "description": "アカウント検索条件:アカウントDBへ問い合わせ:アカウントレコード",
      "external": {
        "db": {
          "schema": "accounts.login"
        }
      },
      "imports": [
        "dto/in/OrderInDto",
        "dto/out/OrderOutDto"
      ]
    }
  ],
  "dto": {
    "in": [
      "OrderInDto"
    ],
    "out": [
      "OrderOutDto"
    ]
  }
}
